---
import '../styles/global.css';
import '../styles/transitions.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<meta name="generator" content={Astro.generator} />
<script is:inline>
  const updateDayOfYear = () => {
    const JANUARY = 0;
    const FIRST_DAY_OF_MONTH = 1;
    const MILLISECONDS_IN_DAY = 86_400_000;

    const now = new Date();
    const startOfYear = new Date(now.getFullYear(), JANUARY, FIRST_DAY_OF_MONTH);
    const dayOfYear = Math.floor((now.getTime() - startOfYear.getTime()) / MILLISECONDS_IN_DAY);

    document.documentElement.style.setProperty('--day-of-year', String(dayOfYear));
  };

  updateDayOfYear();
</script>

<ClientRouter />

<!-- View Transitions -->
<meta name="view-transition" content="same-origin" />

<!-- PWA -->
<link rel="manifest" href="/manifest.json">

<!-- Sitemap -->
<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@500;600;700;800&display=swap" rel="stylesheet">

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{image && <meta property="og:image" content={new URL(image, Astro.url)} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
{image && <meta property="twitter:image" content={new URL(image, Astro.url)} />}

<!-- Yandex.Metrika counter -->
<script is:inline type="text/javascript" >
  const YANDEX_METRIKA_ID = 99_027_716;
  const SCRIPT_URL = 'https://mc.yandex.ru/metrika/tag.js';
  const LOCAL_HOSTNAMES = new Set(['127.0.0.1', 'localhost']);

  const hasMetrikaScript = (scriptUrl) => {
    for (const scriptElement of document.scripts) {
      if (scriptElement.src === scriptUrl) {
        return true;
      }
    }

    return false;
  };

  const injectMetrikaScript = (scriptUrl) => {
    const metrikaScript = document.createElement('script');
    metrikaScript.async = true;
    metrikaScript.src = scriptUrl;
    document.head.append(metrikaScript);
  };

  const setupYmQueue = () => {
    const ymQueueProperty = 'a';
    const ymLoadTimeProperty = 'l';

    globalThis.ym = (...arguments_) => {
      const ymQueue = globalThis.ym[ymQueueProperty] ?? [];
      ymQueue.push(arguments_);
      globalThis.ym[ymQueueProperty] = ymQueue;
    };
    globalThis.ym[ymLoadTimeProperty] = Date.now();
  };

  const initializeYandexMetrika = () => {
    if (LOCAL_HOSTNAMES.has(globalThis.location.hostname)) {
      return;
    }

    if (hasMetrikaScript(SCRIPT_URL)) {
      return;
    }

    injectMetrikaScript(SCRIPT_URL);

    if (typeof globalThis.ym !== 'function') {
      setupYmQueue();
    }

    globalThis.ym(YANDEX_METRIKA_ID, 'init', {
      accurateTrackBounce: true,
      clickmap: true,
      trackLinks: true,
    });
  };

  initializeYandexMetrika();
</script>
<!-- /Yandex.Metrika counter -->
