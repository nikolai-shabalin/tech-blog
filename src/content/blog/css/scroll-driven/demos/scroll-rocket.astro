    <path d="M9.479 14.361c-.48.093-.98.139-1.479.139s-.999-.046-1.479-.139L7.6 15.8a.5.5 0 0 0 .8 0z"/>

    <!-- Fire group: hidden at zero scroll, appears on first pixel -->
    <g class="rocket-flames">

    <!-- Fire: outer red halo -->
    <ellipse cx="8" cy="17.4" rx="2.6" ry="3.0" fill="#ef4444" opacity="0.65">
      <animate attributeName="ry" values="3.0;4.2;2.6;3.8;3.0" dur="0.52s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.65;0.45;0.75;0.5;0.65" dur="0.52s" repeatCount="indefinite"/>
    </ellipse>

    <!-- Fire: orange middle layer -->
    <ellipse cx="8" cy="17.2" rx="1.8" ry="2.5" fill="#f97316" opacity="0.85">
      <animate attributeName="ry" values="2.5;3.4;2.1;3.0;2.5" dur="0.38s" repeatCount="indefinite"/>
      <animate attributeName="cx" values="8;7.7;8.2;7.9;8" dur="0.38s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.85;0.65;0.9;0.7;0.85" dur="0.38s" repeatCount="indefinite"/>
    </ellipse>

    <!-- Fire: yellow core -->
    <ellipse cx="8" cy="16.9" rx="1.1" ry="1.9" fill="#fbbf24" opacity="0.92">
      <animate attributeName="ry" values="1.9;2.7;1.6;2.4;1.9" dur="0.28s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.92;0.72;1;0.8;0.92" dur="0.28s" repeatCount="indefinite"/>
    </ellipse>

    <!-- Fire: white-hot center -->
    <ellipse cx="8" cy="16.5" rx="0.55" ry="1.1" fill="#fef9c3" opacity="0.95">
      <animate attributeName="ry" values="1.1;1.6;0.9;1.4;1.1" dur="0.21s" repeatCount="indefinite"/>
      <animate attributeName="opacity" values="0.95;0.7;1;0.82;0.95" dur="0.21s" repeatCount="indefinite"/>
    </ellipse>

    </g>
  </svg>
</div>

<style>
  .scroll-rocket {
    display: none;
  }

  @media (min-width: 1440px) {
    .scroll-rocket {
      display: block;
      position: fixed;
      bottom: 48px;
      right: 48px;
      z-index: 50;
      color: #6366f1;
      filter: drop-shadow(0 4px 12px rgba(99, 102, 241, 0.4));
      pointer-events: none;
      animation: rocketFly linear both;
      animation-timeline: scroll(root block);
    }
  }

  .rocket-flames {
    animation: fireReveal linear both;
    animation-timeline: scroll(root block);
    animation-range: 0px 1px;
  }

  @keyframes fireReveal {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes rocketFly {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-75vh);
    }
  }
</style>
