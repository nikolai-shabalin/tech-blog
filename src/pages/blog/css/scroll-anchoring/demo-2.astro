<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Scroll Anchoring: Отключение якорения в чате</title>
		<meta
			name="description"
			content="Демо infinite-scroll чата с подгрузкой старых сообщений сверху и сравнением поведения с overflow-anchor: none и без него."
		/>
	</head>
	<body>
		<main class="page">
			<h1>Пример 2: Отключение якорения (`overflow-anchor: none`)</h1>
			<p class="lead">
				Прокрутите чат к середине, затем нажмите «Загрузить старые сообщения». С включенным `overflow-anchor: none` список ведет себя предсказуемо и
				контроль остается у вашего скрипта.
			</p>
			<p class="lead">
				Для сравнения отключите галочку и повторите действие: браузер начнет удерживать текущий видимый элемент (якорь), из-за чего может появиться
				неприятный визуальный рывок.
			</p>

			<div class="controls">
				<label class="checkbox">
					<input id="disable-anchoring" type="checkbox" checked />
					Применить `overflow-anchor: none` к контейнеру
				</label>
				<button id="reset-demo" type="button">Сбросить демо</button>
			</div>

			<div class="chat no-anchor" id="chat">
				<div class="message">Новое сообщение 1</div>
				<div class="message">Новое сообщение 2</div>
				<div class="message">Новое сообщение 3</div>
				<div class="message">Новое сообщение 4</div>
				<div class="message">Новое сообщение 5</div>
				<div class="message">Новое сообщение 6</div>
				<div class="message">Новое сообщение 7</div>
				<div class="message">Новое сообщение 8</div>
				<div class="message">Новое сообщение 9</div>
				<div class="message" id="current-view">Сообщение, которое читают</div>
				<div class="message">Старое сообщение 10</div>
				<div class="message">Старое сообщение 11</div>
				<div class="message">Старое сообщение 12</div>
				<div class="message">Старое сообщение 13</div>
			</div>

			<button id="load-more" class="load-button" type="button">Загрузить старые сообщения</button>
			<p class="status" id="status">Статус: `overflow-anchor: none` включен.</p>
		</main>
	</body>
</html>

<script>
	const chat = document.getElementById('chat');
	const button = document.getElementById('load-more');
	const resetButton = document.getElementById('reset-demo');
	const disableAnchoringCheckbox = document.getElementById('disable-anchoring');
	const status = document.getElementById('status');

	let seed = 100;

	function setStatus(text: string) {
		if (status instanceof HTMLElement) {
			status.textContent = text;
		}
	}

	function addOldMessages() {
		if (!(chat instanceof HTMLElement)) {
			return;
		}

		for (let i = 0; i < 3; i++) {
			seed += 1;
			const oldMsg = document.createElement('div');
			oldMsg.className = 'message historical';
			oldMsg.textContent = `Загруженное историческое сообщение #${seed}`;
			chat.insertBefore(oldMsg, chat.firstChild);
		}
	}

	function resetChat() {
		if (!(chat instanceof HTMLElement)) {
			return;
		}

		const loadedMessages = chat.querySelectorAll('.message.historical');
		for (const message of loadedMessages) {
			message.remove();
		}

		chat.scrollTop = 160;
	}

	if (button instanceof HTMLButtonElement) {
		button.addEventListener('click', () => {
			addOldMessages();
			setStatus('Статус: загружены 3 старых сообщения.');
		});
	}

	if (disableAnchoringCheckbox instanceof HTMLInputElement && chat instanceof HTMLElement) {
		disableAnchoringCheckbox.addEventListener('change', () => {
			chat.classList.toggle('no-anchor', disableAnchoringCheckbox.checked);
			const mode = disableAnchoringCheckbox.checked ? 'включен' : 'выключен';
			setStatus(`Статус: overflow-anchor: none ${mode}.`);
		});
	}

	if (resetButton instanceof HTMLButtonElement && disableAnchoringCheckbox instanceof HTMLInputElement) {
		resetButton.addEventListener('click', () => {
			seed = 100;
			resetChat();
			disableAnchoringCheckbox.checked = true;
			if (chat instanceof HTMLElement) {
				chat.classList.add('no-anchor');
			}
			setStatus('Статус: демо сброшено. Прокрутите чат и повторите эксперимент.');
		});
	}

	resetChat();
</script>

<style>
	:root {
		color-scheme: dark;
	}

	body {
		margin: 0;
		font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
		background: #0f0f10;
		color: #f5f5f5;
	}

	.page {
		max-width: 760px;
		margin: 0 auto;
		padding: 2rem 1rem 3rem;
	}

	h1 {
		margin: 0 0 0.8rem;
		font-size: clamp(1.35rem, 3vw, 2rem);
	}

	.lead {
		margin: 0 0 1rem;
		color: #d6d6d8;
		line-height: 1.55;
	}

	.controls {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem 1.2rem;
		align-items: center;
		margin-bottom: 1rem;
	}

	.checkbox {
		display: inline-flex;
		gap: 0.55rem;
		align-items: center;
		font-size: 0.95rem;
	}

	.chat {
		width: min(420px, 100%);
		height: 260px;
		overflow-y: auto;
		border: 1px solid #4e4e52;
		border-radius: 12px;
		padding: 0.65rem;
		background: #17171a;
	}

	.chat.no-anchor {
		overflow-anchor: none;
	}

	.message {
		border: 1px solid #3f3f44;
		padding: 0.45rem 0.55rem;
		margin: 0.35rem 0;
		border-radius: 8px;
		background: #232328;
		color: #e6e6e9;
	}

	.message.historical {
		background: #2a3342;
		border-color: #3f5d86;
	}

	#current-view {
		border-color: #4f7fc2;
		background: #20314f;
	}

	.load-button,
	#reset-demo {
		margin-top: 0.9rem;
		border: 1px solid #6e6e76;
		background: #202024;
		color: #f8f8f8;
		border-radius: 8px;
		padding: 0.55rem 0.8rem;
		font: inherit;
		cursor: pointer;
	}

	.status {
		margin-top: 0.8rem;
		color: #a6d7ff;
		font-size: 0.95rem;
	}
</style>
