---
import BaseHead from '../../../components/base-head.astro';
import Footer from '../../../components/footer.astro';
import Header from '../../../components/header.astro';
import PostsList from '../../../components/posts-list.astro';
import { SITE_TITLE } from '../../../consts';
import { getCollection } from 'astro:content';

export const getStaticPaths = () =>
  getCollection('blog').then((allPosts) => {
    const ROOT_SEGMENT_INDEX = 0;
    const uniqueCategories = [...new Set(
      allPosts.map((post) => {
        const pathSegments = post.id.split('/');
        return pathSegments[ROOT_SEGMENT_INDEX].toLowerCase();
      }),
    )];

    return uniqueCategories.map((category) => {
      const filteredPosts = allPosts.filter(
        (post) => post.id.split('/')[ROOT_SEGMENT_INDEX].toLowerCase() === category,
      );

      return {
        params: { category },
        props: { posts: filteredPosts },
      };
    });
  });

const { category } = Astro.params;
const { posts } = Astro.props;

const sortedPosts = posts.toSorted(
  (firstPost, secondPost) => secondPost.data.pubDate.valueOf() - firstPost.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ru">
	<head>
		<BaseHead title={`${category} | ${SITE_TITLE}`} description={`Статьи в категории ${category}`} />
	</head>
	<body>
		<Header />
		<main>
      <h1 class="sr-only">Категория: {category}</h1>
			<PostsList posts={sortedPosts} />
		</main>
		<Footer />
	</body>
</html>
